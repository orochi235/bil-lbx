{
  "name": "bil-lbx",
  "version": "0.1.0",
  "description": "Generate Brother P-touch .lbx label files programmatically",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orochi235/bil-lbx.git"
  },
  "homepage": "https://github.com/orochi235/bil-lbx#readme",
  "bugs": "https://github.com/orochi235/bil-lbx/issues",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "brother",
    "p-touch",
    "label",
    "lbx",
    "printer"
  ],
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^5.9.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
